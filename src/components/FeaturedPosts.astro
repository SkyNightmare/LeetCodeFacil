---
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/date';

// Get all blog posts, sort by publication date
const allPosts = await getCollection('blog');
const featuredPosts = allPosts
  .filter(post => post.data.featured)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

// If there aren't enough featured posts, use recent posts
const posts = featuredPosts.length >= 3 
  ? featuredPosts 
  : [
      ...featuredPosts,
      ...allPosts
        .filter(post => !post.data.featured)
        .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
        .slice(0, 3 - featuredPosts.length)
    ];
---

<section>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {posts.map((post, index) => (
      <a 
        href={`/blog/${post.slug}`}
        class:list={[
          "group overflow-hidden rounded-xl border border-dark-200 hover:shadow-lg transition-all duration-300 hover:-translate-y-1",
          index === 0 ? "md:col-span-2 md:row-span-2" : ""
        ]}
      >
        <div class:list={[
          "relative flex flex-col h-full",
          index === 0 ? "md:aspect-[16/9]" : "aspect-[3/2]"
        ]}>
          {post.data.heroImage && (
            <img 
              src={post.data.heroImage.src}
              alt={post.data.heroImage.alt || post.data.title}
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
              loading={index === 0 ? "eager" : "lazy"}
            />
          )}
          
          <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 via-dark-900/30 to-transparent"></div>
          
          <div class="relative mt-auto p-6 text-white z-10">
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="mb-3">
                <span class="inline-block px-3 py-1 text-xs font-medium bg-primary-600 rounded-full">
                  {post.data.tags[0]}
                </span>
              </div>
            )}
            
            <h3 class:list={[
              "font-bold group-hover:text-primary-300 transition-colors mb-2",
              index === 0 ? "text-2xl md:text-3xl" : "text-xl"
            ]}>
              {post.data.title}
            </h3>
            
            {index === 0 && (
              <p class="text-white/80 mb-3 line-clamp-2 hidden md:block">
                {post.data.description}
              </p>
            )}
            
            <div class="text-sm text-white/70">
              {formatDate(post.data.pubDate)}
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>