---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/date';
import PostTagList from './PostTagList.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
  showHeading?: boolean;
  heading?: string;
}

const { posts, showHeading = true, heading = "Latest Posts" } = Astro.props;
---

<div>
  {showHeading && <h2 class="text-2xl md:text-3xl font-bold mb-8 text-dark-900">{heading}</h2>}
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {posts.map(post => (
      <article class="flex flex-col bg-white border border-dark-200 rounded-lg overflow-hidden hover:shadow-md transition-shadow">
        <a href={`/blog/${post.slug}`} class="group">
          {post.data.heroImage && (
            <div class="aspect-video overflow-hidden">
              <img 
                src={post.data.heroImage.src} 
                alt={post.data.heroImage.alt || post.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          )}
        </a>
        
        <div class="flex flex-col flex-grow p-5">
          <div class="mb-3">
            <PostTagList tags={post.data.tags || []} />
          </div>
          
          <h3 class="text-xl font-bold mb-2">
            <a 
              href={`/blog/${post.slug}`}
              class="text-dark-900 hover:text-primary-600 transition-colors"
            >
              {post.data.title}
            </a>
          </h3>
          
          <p class="text-dark-600 mb-4 line-clamp-2">
            {post.data.description}
          </p>
          
          <div class="mt-auto flex items-center justify-between text-sm text-dark-500">
            <time datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            
            <a 
              href={`/blog/${post.slug}`}
              class="inline-flex items-center font-medium text-primary-600 hover:text-primary-700"
            >
              Read more
              <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>
  
  {posts.length === 0 && (
    <div class="text-center py-12">
      <p class="text-lg text-dark-600">No posts found.</p>
    </div>
  )}
</div>