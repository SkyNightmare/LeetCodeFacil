---
---

<div class="bg-primary-50 rounded-xl p-6 md:p-8">
  <div class="text-center max-w-2xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold mb-3 text-dark-900">
      Subscribete al Newsletter
    </h2>
    <p class="text-dark-700 mb-6">
      Obten las notificaciones directamente a tu inbox cuando se agregue un leetcode nuevo.
    </p>
    <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input
        type="email"
        placeholder="Your email address"
        class="flex-1 px-4 py-3 rounded-md border border-dark-200 focus:outline-none focus:ring-2 focus:ring-primary-500"
        required
      />
      <button
        type="submit"
        class="px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-md transition-colors"
      >
        Subscribe
      </button>
    </form>
    <p class="text-xs text-dark-500 mt-4">
      No spam. Unsubscribete en cualquier momento. Tu email no sera compartido.
    </p>
  </div>
</div>