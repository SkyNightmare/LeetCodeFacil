---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/date';

interface Props {
  currentPost: CollectionEntry<'blog'>;
  tags: string[];
  count?: number;
}

const { currentPost, tags, count = 3 } = Astro.props;

// Get all blog posts
const posts = await getCollection('blog');

// Filter out the current post and find ones with matching tags
const relatedPosts = posts
  .filter(post => post.id !== currentPost.id)
  .filter(post => {
    const postTags = post.data.tags || [];
    
    return tags.some(tag => postTags.includes(tag));
  })
  .slice(0, count);

let postsToShow = [...relatedPosts];
if (postsToShow.length < count) {
  const recentPosts = posts
    .filter(post => post.id !== currentPost.id && !postsToShow.some(p => p.id === post.id))
    .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
    .slice(0, count - postsToShow.length);
  
  postsToShow = [...postsToShow, ...recentPosts];
}
---

{postsToShow.length > 0 && (
  <div>
    <h2 class="text-2xl font-bold mb-6 text-dark-900">Related Posts</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {postsToShow.map(post => (
        <a href={`/blog/${post.slug}`} class="group">
          <div class="h-full flex flex-col rounded-lg border border-dark-200 overflow-hidden transition-transform hover:shadow-md hover:-translate-y-1">
            {post.data.heroImage && (
              <div class="aspect-video overflow-hidden">
                <img 
                  src={post.data.heroImage.src} 
                  alt={post.data.heroImage.alt || post.data.title} 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-4 flex-grow flex flex-col">
              <div class="mb-2 text-xs text-dark-500">
                {formatDate(post.data.pubDate)}
              </div>
              <h3 class="text-lg font-semibold mb-2 text-dark-800 group-hover:text-primary-600 transition-colors">
                {post.data.title}
              </h3>
              <p class="text-sm text-dark-600 mb-3 line-clamp-2">
                {post.data.description}
              </p>
              {post.data.tags && (
                <div class="mt-auto flex flex-wrap gap-2">
                  {post.data.tags.slice(0, 2).map(tag => (
                    <span class="text-xs px-2 py-1 bg-primary-50 text-primary-700 rounded-full">
                      #{tag}
                    </span>
                  ))}
                  {post.data.tags.length > 2 && (
                    <span class="text-xs px-2 py-1 bg-dark-50 text-dark-500 rounded-full">
                      +{post.data.tags.length - 2} more
                    </span>
                  )}
                </div>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
)}