---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact - LeetCode Programming Blog">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl md:text-4xl font-bold mb-6 text-dark-900">
      Contact Us
    </h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div>
        <p class="text-lg text-dark-700 mb-6">
          Have questions, suggestions, or want to collaborate? We'd love to hear from you! Fill out the form and we'll get back to you as soon as possible.
        </p>
        
        <div class="space-y-6">
          <div>
            <h2 class="text-xl font-semibold mb-2 text-dark-800">Email</h2>
            <a href="mailto:hello@leetcodeblog.com" class="text-primary-600 hover:text-primary-700">
              hello@leetcodeblog.com
            </a>
          </div>
          
          <div>
            <h2 class="text-xl font-semibold mb-2 text-dark-800">Social Media</h2>
            <div class="flex space-x-4">
              <a href="#" class="text-dark-600 hover:text-primary-600">Twitter</a>
              <a href="#" class="text-dark-600 hover:text-primary-600">GitHub</a>
              <a href="#" class="text-dark-600 hover:text-primary-600">LinkedIn</a>
            </div>
          </div>
        </div>
      </div>
      
      <div>
        <form class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium text-dark-700 mb-1">Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              class="w-full px-4 py-2 border border-dark-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500"
              required
            />
          </div>
          
          <div>
            <label for="email" class="block text-sm font-medium text-dark-700 mb-1">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              class="w-full px-4 py-2 border border-dark-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500"
              required
            />
          </div>
          
          <div>
            <label for="subject" class="block text-sm font-medium text-dark-700 mb-1">Subject</label>
            <input 
              type="text" 
              id="subject" 
              name="subject" 
              class="w-full px-4 py-2 border border-dark-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500"
              required
            />
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium text-dark-700 mb-1">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="5" 
              class="w-full px-4 py-2 border border-dark-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500"
              required
            ></textarea>
          </div>
          
          <div>
            <button 
              type="submit" 
              class="w-full px-6 py-3 bg-primary-600 text-white font-medium rounded-md hover:bg-primary-700 transition-colors"
            >
              Send Message
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>